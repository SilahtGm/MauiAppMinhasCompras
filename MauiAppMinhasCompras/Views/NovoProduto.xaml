<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppMinhasCompras.Views.NovoProduto"
             Title="Novo Produto">

   

    <VerticalStackLayout Spacing="10" Padding="10">
        <Label Text="Descrição do Produto:" />
        <Entry 
        x:Name="txt_descricao"
        Placeholder="Digite a descrição do produto" />

        <Label Text="Categoria do produto:" />
        <Picker x:Name="picker_categoria" Title="Selecione uma categoria">
            <Picker.Items>
                <x:String>Alimentos</x:String>
                <x:String>Higiene</x:String>
                <x:String>Lazer</x:String>
                <x:String>Limpeza</x:String>
                <x:String>Farmácia</x:String>
            </Picker.Items>
        </Picker>

        <Label Text="Quantidade:" />
        <Entry 
        x:Name="txt_quantidade"
        Keyboard="Numeric"
        Placeholder="Digite a quantidade" />

        <Label Text="Preço Unitário:" />
        <Entry 
        x:Name="txt_preco"
        Keyboard="Numeric"
        Placeholder="Digite o preço" />

        <Button
        Text="Salvar"
        Clicked="Salvar_Clicked"/>

        <Button
        Text="Cancelar"
        Clicked="Cancelar_Clicked"/>

    </VerticalStackLayout>
</ContentPage>